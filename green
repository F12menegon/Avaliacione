var ledTopo = 0;   // LED Vermelho
var ledMeio = 1;   // LED Verde
var ledBaixo = 2;  // LED Amarelo

function setup() {
	pinMode(ledTopo, OUTPUT);
	pinMode(ledMeio, OUTPUT);
	pinMode(ledBaixo, OUTPUT);
}

function loop() {
	digitalWrite(ledTopo, LOW);   // Desliga Vermelho
	digitalWrite(ledMeio, HIGH);  // LIGA Verde
	digitalWrite(ledBaixo, LOW);  // Desliga Amarelo
	delay(100);
}
